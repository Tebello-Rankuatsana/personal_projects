# 3. QUIZZES
###############################################

### 3.1 — Generate a multiple choice quiz (from all subject docs)
POST {{baseUrl}}/quizzes/generate
Content-Type: {{contentType}}

{
  "subject": "{{subject}}",
  "type": "multiple_choice",
  "count": 3,
  "title": "Biology Multiple Choice Test"
}

### 3.2 — Generate a true/false quiz
POST {{baseUrl}}/quizzes/generate
Content-Type: {{contentType}}

{
  "subject": "{{subject}}",
  "type": "true_false",
  "count": 5
}

### 3.3 — Generate a short answer quiz
POST {{baseUrl}}/quizzes/generate
Content-Type: {{contentType}}

{
  "subject": "{{subject}}",
  "type": "short_answer",
  "count": 3
}

### 3.4 — Generate quiz from a specific document
POST {{baseUrl}}/quizzes/generate
Content-Type: {{contentType}}

{
  "subject": "{{subject}}",
  "type": "multiple_choice",
  "count": 5,
  "doc_id": "{{docId}}"
}

### 3.5 — Generate quiz on a specific topic (uses RAG)
POST {{baseUrl}}/quizzes/generate
Content-Type: {{contentType}}

{
  "subject": "{{subject}}",
  "type": "multiple_choice",
  "count": 3,
  "topic": "photosynthesis light reactions"
}

### 3.6 — List all quizzes
GET {{baseUrl}}/quizzes

### 3.7 — List quizzes filtered by subject
GET {{baseUrl}}/quizzes?subject={{subject}}

### 3.8 — Get a specific quiz with questions and attempts
GET {{baseUrl}}/quizzes/{{quizId}}

### 3.9 — Submit a quiz attempt (replace question IDs after running 3.8)
POST {{baseUrl}}/quizzes/{{quizId}}/attempt
Content-Type: {{contentType}}

{
  "answers": {
    "{{questionId}}": "A"
  }
}


